# ── Google OAuth & Gmail ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GMAIL_PUBSUB_TOPIC=projects/YOUR_PROJECT/topics/gmail-notifications
GMAIL_USER_EMAIL=solutions@3rdaillc.com

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── OpenAI (embeddings) ──
OPENAI_API_KEY=

# ── Anthropic (RAG answers) ──
ANTHROPIC_API_KEY=

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
WORKER_PORT=3001

# ── WhatsApp Cloud API (optional — omit to disable) ──
# Get these from Meta Developer Dashboard → your app → WhatsApp settings
WHATSAPP_VERIFY_TOKEN=          # Webhook verification token (you define this)
WHATSAPP_ACCESS_TOKEN=          # Permanent access token from Meta
WHATSAPP_APP_SECRET=            # App secret for webhook signature validation
WHATSAPP_PHONE_NUMBER_ID=       # Phone number ID from WhatsApp Business

# Session compiler tuning (optional — sane defaults)
# WHATSAPP_SESSION_IDLE_TIMEOUT_MINUTES=120     # Minutes of silence before a session is "complete"
# WHATSAPP_SESSION_COMPILE_INTERVAL_MINUTES=30  # How often the compiler checks for idle sessions
